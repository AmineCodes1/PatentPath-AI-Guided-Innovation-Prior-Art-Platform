# PatentPath environment variables
# Copy this file to .env and replace placeholder values.

# Database and cache
POSTGRES_DB=patentpath
POSTGRES_USER=patentpath
POSTGRES_PASSWORD=change_me
DATABASE_URL=postgresql+asyncpg://patentpath:change_me@postgres:5432/patentpath
REDIS_URL=redis://redis:6379/0

# EPO OPS credentials
EPO_CONSUMER_KEY=your_epo_consumer_key
EPO_CONSUMER_SECRET=your_epo_consumer_secret

# Anthropic API
ANTHROPIC_API_KEY=your_anthropic_api_key

# Auth
JWT_SECRET_KEY=replace_with_a_64_char_secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# API and CORS
CORS_ORIGINS=http://localhost:5173,http://localhost
